{
  "name": "nano-agent",
  "version": "0.11.0",
  "description": "A lightweight, general-purpose AI agent for real work, built with TypeScript and the OpenAI Agents SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kickflip73/NanoAgent.git"
  },
  "homepage": "https://github.com/Kickflip73/NanoAgent#readme",
  "main": "./dist/agent.js",
  "types": "./dist/agent.d.ts",
  "exports": {
    ".": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js",
      "default": "./dist/agent.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration.d.ts",
      "import": "./dist/orchestration.js",
      "default": "./dist/orchestration.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "nano-agent": "dist/index.js",
    "nano": "dist/index.js"
  },
  "bugs": {
    "url": "https://github.com/Kickflip73/NanoAgent/issues"
  },
  "keywords": [
    "ai-agent",
    "openai-agents-sdk",
    "deepseek",
    "mcp",
    "rag",
    "agent-skills",
    "subagents",
    "long-running-agents",
    "typescript",
    "cli"
  ],
  "files": [
    "src",
    "dist",
    "skills/code-review",
    "skills/research",
    "skills/web-research",
    "knowledge",
    "evals",
    "docs/ARCHITECTURE.md",
    "NANO.md",
    ".env.example",
    "mcp.example.json",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "tsconfig.json",
    "tsconfig.build.json"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "eval": "tsx src/eval.ts",
    "eval:agent": "tsx src/agent-eval.ts",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" --test-coverage-lines=85 --test-coverage-branches=75 --test-coverage-functions=75 --import tsx --test tests/*.test.ts",
    "test:package": "node tests/package-smoke.mjs",
    "ci": "npm run check && npm run test:coverage && npm run build && npm run test:package"
  },
  "dependencies": {
    "@openai/agents": "^0.13.2",
    "dotenv": "^17.0.0",
    "openai": "^6.46.0",
    "undici": "^8.7.0",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
