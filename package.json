{
  "name": "nano-agent",
  "version": "0.5.0",
  "description": "A tiny, educational AI agent built with TypeScript and the OpenAI Agents SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kickflip73/NanoAgent.git"
  },
  "homepage": "https://github.com/Kickflip73/NanoAgent#readme",
  "bin": {
    "nano": "dist/index.js"
  },
  "bugs": {
    "url": "https://github.com/Kickflip73/NanoAgent/issues"
  },
  "keywords": [
    "ai-agent",
    "openai-agents-sdk",
    "deepseek",
    "mcp",
    "rag",
    "agent-skills",
    "typescript",
    "cli"
  ],
  "files": [
    "src",
    "dist",
    "skills/code-review",
    "skills/research",
    "knowledge",
    "evals",
    "docs",
    ".env.example",
    "mcp.json",
    "mcp.example.json",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "tsconfig.json",
    "tsconfig.build.json"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "eval": "tsx src/eval.ts",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@openai/agents": "^0.13.2",
    "dotenv": "^17.0.0",
    "undici": "^8.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
