# Choose: openai or deepseek
MODEL_PROVIDER=openai

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
# Optional comma-separated choices shown by /model
# OPENAI_MODELS=gpt-5.4-mini,gpt-5.4,gpt-5-mini

DEEPSEEK_API_KEY=replace-with-a-new-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash

# === Web Search (optional) ===
# Google Custom Search: https://programmablesearchengine.google.com/ (free, 100 queries/day)
# GOOGLE_CSE_API_KEY=your-api-key
# GOOGLE_CSE_CX=your-search-engine-id

# Optional runtime settings
MAX_TURNS=200
HISTORY_LIMIT=40
# Global overrides; normally model profiles choose these automatically.
# CONTEXT_WINDOW=128000
# OUTPUT_TOKEN_RESERVE=16384
# Model-specific overrides take precedence, e.g.:
# DEEPSEEK_V4_PRO_CONTEXT_WINDOW=1048576
# DEEPSEEK_V4_PRO_OUTPUT_RESERVE=65536
OUTPUT_LEVEL=tools
# AGENT_MODE=general
# Built-in local tool boundary: workspace, read-only, or trusted.
AGENT_PERMISSION_MODE=workspace
# TEAM_MAX_CONCURRENCY=4
# AGENT_WORKSPACE=/path/to/workspace
# AGENT_SESSION=default
# AGENT_DATA_DIR=/path/to/runtime-data
# AGENT_SKILLS_DIR=/path/to/skills
# MCP_CONFIG=/path/to/mcp.json
# Project mcp.json is disabled unless the workspace is explicitly trusted.
# TRUST_WORKSPACE_MCP=/absolute/path/to/trusted/workspace
# MCP_TOKEN=token-referenced-by-mcp-json
# EMBEDDING_MODEL=text-embedding-3-small
