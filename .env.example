# Choose: openai or deepseek
MIMI_CONFIG_VERSION=4
MIMI_MODEL_PROVIDER=openai

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
# Optional comma-separated choices shown by /model
# OPENAI_MODELS=gpt-5.4-mini,gpt-5.4,gpt-5-mini

DEEPSEEK_API_KEY=replace-with-a-new-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash

# === Web Search (optional) ===
# Google Custom Search: https://programmablesearchengine.google.com/ (free, 100 queries/day)
# GOOGLE_CSE_API_KEY=your-api-key
# GOOGLE_CSE_CX=your-search-engine-id

# Optional runtime settings
# MIMI_MAX_TURNS=200
MIMI_HISTORY_LIMIT=40
# Global overrides; normally model profiles choose these automatically.
# MIMI_CONTEXT_WINDOW=128000
# MIMI_OUTPUT_TOKEN_RESERVE=16384
# Model-specific overrides take precedence, e.g.:
# DEEPSEEK_V4_PRO_CONTEXT_WINDOW=1048576
# DEEPSEEK_V4_PRO_OUTPUT_RESERVE=65536
MIMI_OUTPUT_LEVEL=tools
# MIMI_MODE=general
# New installations start in Safe. Choose workstation or full-owner explicitly
# after reviewing the effective capability summary shown by /status.
MIMI_SECURITY_PROFILE=safe
MIMI_PERMISSION_MODE=read-only
# 可选：Codex CLI 不在 PATH 或常见安装目录时指定绝对路径
# MIMI_CODEX_PATH=/absolute/path/to/codex

# 可选：本机 macOS Computer Use（默认不创建、不连接 Driver）
# MIMI_COMPUTER_BACKEND=cua
# MIMI_CUA_DRIVER_COMMAND=/absolute/path/to/cua-driver
# MIMI_COMPUTER_ACTION_TIMEOUT_MS=15000
# MIMI_COMPUTER_MAX_ACTIONS_PER_RUN=50
# MIMI_COMPUTER_MAX_SCREENSHOTS_PER_RUN=12
# MIMI_COMPUTER_PAUSE_WHEN_TARGET_FRONTMOST=true
# MIMI_COMPUTER_DEFAULT_ACCESS=background
# MIMI_COMPUTER_FOREGROUND_LEASE_SECONDS=30
# MIMI_COMPUTER_ARTIFACT_MAX_MIB=1024
# 自定义模型必须显式声明是否接受图像输入；内置模型已有固定 profile
# MIMI_MODEL_SUPPORTS_IMAGE_INPUT=true
# Old versionless workspace defaults migrate to trusted; keep the version marker
# when deliberately selecting a security profile or permission mode.
# MIMI_TEAM_MAX_CONCURRENCY=4
# MIMI_SESSION_MAX_CONCURRENCY=4
# MIMI_WORKSPACE=/path/to/workspace
# MIMI_SESSION=default
# MIMI_DATA_DIR=/path/to/runtime-data
# MIMI_DAEMON_DATA_DIR=~/.mimi-agent/daemon
# MIMI_ENV_FILE=~/.mimi-agent/.env
# Explicit legacy aliases remain supported when no MIMI_* equivalent is set:
# MODEL_PROVIDER; AGENT_WORKSPACE/DATA_DIR/SKILLS_DIR/PERMISSION_MODE/SESSION/MODE;
# JARVIS_DATA_DIR/CONNECTORS_CONFIG/ASSISTANT_CONFIG/WEBHOOK_PORT/WEBHOOK_TOKEN;
# MCP_CONFIG, TRUST_WORKSPACE_MCP, MAX_TURNS, HISTORY_LIMIT, CONTEXT_WINDOW,
# OUTPUT_TOKEN_RESERVE, TEAM_MAX_CONCURRENCY, OUTPUT_LEVEL and DOTENV_CONFIG_PATH.
# MIMI_CONNECTORS_CONFIG=~/.mimi-agent/daemon/connectors.json
# MIMI_ASSISTANT_CONFIG=~/.mimi-agent/daemon/assistant.json
# Optional native system health thresholds; the macOS Connector is enabled on first initialization.
# MACOS_SYSTEM_POLL_INTERVAL_MS=60000
# MACOS_SYSTEM_BATTERY_LOW_PERCENT=20
# MACOS_SYSTEM_BATTERY_CRITICAL_PERCENT=10
# MACOS_SYSTEM_DISK_MIN_PERCENT=10
# MACOS_SYSTEM_DISK_MIN_GB=10
# Optional localhost-only authenticated event webhook.
# MIMI_WEBHOOK_PORT=7788
# MIMI_WEBHOOK_TOKEN=generate-a-random-secret-at-least-24-characters
# Optional fixed HTTP relay for arbitrary external actions and reply delivery.
# Legacy JARVIS_HTTP_* names remain fallback aliases.
# MIMI_HTTP_ACTION_URL=https://relay.example.com/mimi
# MIMI_HTTP_EVENT_URL=https://relay.example.com/mimi/events
# MIMI_HTTP_ACTION_TOKEN=replace-with-relay-token
# Optional information/file radar definitions used by the packaged connectors.
# MIMI_RADAR_CONFIG=/absolute/path/to/radar.json
# MIMI_FILE_RADAR_CONFIG=/absolute/path/to/file-radar.json

# Optional real IM bridges. Keep credentials in ~/.mimi-agent/.env (or the legacy fallback), never commit them.
# Daxiang outbound requires an enabled and published Open Platform robot. Inbound events
# additionally require the official event-subscription relay described in docs/CONNECTORS.md.
# DX_APP_KEY=your-app-key
# DX_APP_SECRET=your-app-secret
# DX_ROBOT_ID=your-robot-id
# DX_ENV=prod
# DX_CONTENT_TYPE=text

# QQ can use OneBot hosted inside the visible desktop QQ (LLOneBot/LLBot).
# QQ_ONEBOT_HTTP_URL=http://127.0.0.1:3000
# QQ_ONEBOT_WS_PORT=3080
# QQ_ONEBOT_ACCESS_TOKEN=replace-with-onebot-token
# QQ_ONEBOT_WS_ACCESS_TOKEN=replace-with-onebot-websocket-token
# QQ_ONEBOT_STATUS_POLL_MS=30000
# Legacy/separate NapCat mode remains supported through NC_* variables.
# NC_HTTP_URL=http://127.0.0.1:3000
# NC_WS_PORT=3080
# HTTP Server token. Also used for reverse WebSocket authentication unless the next value is set.
# NC_ACCESS_TOKEN=replace-with-napcat-token
# Optional separate WebSocket Client token; NC_ACCESS_TOKEN or this value is required.
# NC_WS_ACCESS_TOKEN=replace-with-napcat-websocket-token
# Background OneBot readiness polling interval.
# NC_STATUS_POLL_MS=30000
# MIMI_HTTP_ACTION_TIMEOUT_MS=30000
# MIMI_HTTP_ACTION_MAX_RESPONSE_BYTES=1048576
# MIMI_HTTP_EVENT_POLL_INTERVAL_MS=5000
# MIMI_SKILLS_DIR=/path/to/skills
# MIMI_MCP_CONFIG=/path/to/mcp.json
# Project mcp.json is disabled unless the workspace is explicitly trusted.
# MIMI_TRUST_WORKSPACE_MCP=/absolute/path/to/trusted/workspace
# MCP_TOKEN=token-referenced-by-mcp-json
# EMBEDDING_MODEL=text-embedding-3-small
# MIMI_MEMORY_RETRIEVAL_MODE=auto
